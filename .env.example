# ─── Banco de Dados MySQL Trucadão ───────────────────────────────────────
DB_HOST=SEU_HOST_AQUI
DB_PORT=3306
DB_USER=SEU_USUARIO_AQUI
DB_PASS=SUA_SENHA_AQUI
DB_NAME=SEU_BANCO_AQUI

# ─── Porta da API (padrão 3001) ──────────────────────────────────────────
PORT=3001

# ─── Google Sheets CSV URL (para custos financeiros) ─────────────────────
# Como obter: Planilha Google → Arquivo → Compartilhar → Publicar na Web → CSV
# Cole a URL gerada abaixo:
SHEETS_CSV_URL=

# ─── Preço do plano (R$) ─────────────────────────────────────────────────
# Preço mensal das revendas recorrentes (tipo J)
PLANO_PRECO=99.90
